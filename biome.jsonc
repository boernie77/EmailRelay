{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "files": {
    "includes": ["!node_modules", "!**/__pycache__", "!*.py"]
  },
  "javascript": {
    "globals": ["chrome", "browser"]
  },
  "linter": {
    "rules": {
      "performance": {
        "useTopLevelRegex": "off"
      }
    }
  }
}
